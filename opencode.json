{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["docs\typescript-guidelines.md"],
  "formatter": true,
  "lsp": true,
  "permission":
   {
    "bash": {
      "git commit *": "ask",
      "git add *": "ask",
      "npm *": "allow",
      "rm *": "deny",
      "grep *": "allow"
    },
    "edit": {
      "*": "deny",
      "packages/web/src/content/docs/*.mdx": "allow"
    }
  }
}