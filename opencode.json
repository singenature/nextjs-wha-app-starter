{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["docs\typescript-guidelines.md"],
  "mcp": {
    "next-devtools-mcp": {
      "type": "local",
      "command": ["npx", "-y", "next-devtools-mcp"],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "ctx7sk-4b0c759c-926b-4382-8ba5-06c64e09d7ef"
      }
    }
  },
  "formatter": true,
  "lsp": true,
  "permission":
   {
    "bash": {
      "git commit *": "ask",
      "git add *": "ask",
      "npm *": "allow",
      "rm *": "deny",
      "grep *": "allow"
    },
    "edit": {
      "*": "deny",
      "packages/web/src/content/docs/*.mdx": "allow"
    }
  }
}